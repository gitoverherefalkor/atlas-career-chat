VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Sentry (frontend error monitoring) — optional. If unset, Sentry is a no-op.
VITE_SENTRY_DSN="https://your-key@your-org.ingest.sentry.io/your-project-id"
VITE_SENTRY_ENVIRONMENT="production"

# --- Server-side secrets (set on Supabase Edge Functions, NOT here) ---
#
# These are configured in the Supabase dashboard under
# Project Settings → Edge Functions → Secrets. They never reach the
# browser bundle, so they are safe for things like n8n webhook URLs and
# shared secrets.
#
# N8N_CHAT_WEBHOOK_URL         the n8n chat webhook URL (was VITE_N8N_CHAT_WEBHOOK_URL)
# N8N_RESUME_WEBHOOK_URL       the n8n resume-extract webhook URL
# N8N_SHARED_SECRET            shared secret for n8n ↔ Supabase calls (see also vault.n8n_shared_secret)
# STRIPE_SECRET_KEY            sk_live_…
# STRIPE_WEBHOOK_SECRET        whsec_…
# RESEND_API_KEY               re_…
# OPENAI_API_KEY               sk-…
# GEMINI_API_KEY               ...
# SUPABASE_SERVICE_ROLE_KEY    the service role JWT
# NEW_N8N_SERVICE_ROLE_KEY     alias of SUPABASE_SERVICE_ROLE_KEY (legacy, used by 6 functions)
